<% flash.each do |type, msg| %>

  <%= msg %>
  
<% end %>

<%= form_with do |form|  %>

  <%= form.label :query, "Check in"  %>
  <%= form.date_field :check_in   %>

  <%= form.label :query, "Check out"  %>
  <%= form.date_field :check_out  %>

  <%= form.label :query, "Number of people"  %>
  <%= form.number_field :num_of_ppl, min:1, max:10 %>

  <%= form.label :query, "Room Type"  %>
  <%= form.collection_select(:room_type_id, RoomType.all, :id, :name) %>
  
  <%= form.submit "Check Availability"   %>
 
<% end %>

